<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.BidRoomController"
            prefWidth="1020"
            prefHeight="720"
            style="-fx-background-color: #f0f2f5;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 14 22; -fx-background-color: white;
                     -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

            <Button text="← Quay lại" onAction="#goBack"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #1e293b;
                           -fx-font-weight: bold; -fx-font-size: 13.5px;
                           -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 8;"/>

            <Label fx:id="itemNameLabel"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Giá hiện tại"
                       style="-fx-font-size: 11.5px; -fx-text-fill: #94a3b8;"/>
                <Label fx:id="currentPriceLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
            </VBox>

            <Label fx:id="timerLabel"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #16a34a;
                          -fx-background-color: #f0fdf4; -fx-background-radius: 8;
                          -fx-padding: 5 14; -fx-border-color: #bbf7d0;
                          -fx-border-width: 1; -fx-border-radius: 8;"/>
        </HBox>
    </top>

    <!-- CENTER: CHART -->
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📈"  style="-fx-font-size: 15px;"/>
                <Label text="Lịch sử đấu giá"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            </HBox>

            <StackPane fx:id="chartContainer"
                       prefHeight="400"
                       style="-fx-background-color: white;
                              -fx-background-radius: 14;
                              -fx-border-color: #e5e7eb;
                              -fx-border-width: 1;
                              -fx-border-radius: 14;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);"/>
        </VBox>
    </center>

    <!-- BOTTOM: ĐẶT GIÁ -->
    <bottom>
        <VBox spacing="14" style="-fx-padding: 18 22; -fx-background-color: white;
                                   -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, -2);">

            <!-- Manual Bid -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Đặt giá:"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #374151;"/>
                <TextField fx:id="bidAmountField"
                           promptText="Nhập số tiền (VNĐ)"
                           prefWidth="280" prefHeight="42"
                           style="-fx-background-radius: 9; -fx-border-radius: 9;
                                  -fx-border-color: #d1d5db; -fx-border-width: 1.5;
                                  -fx-padding: 8 12; -fx-font-size: 13.5px;"/>
                <Button text="💰  ĐẶT GIÁ NGAY" onAction="#handleBid"
                        style="-fx-background-color: #16a34a; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 10 28;
                               -fx-font-size: 14px; -fx-background-radius: 9; -fx-cursor: hand;"/>
            </HBox>

            <!-- Auto Bid -->
            <TitledPane text="🤖  Auto Bidding" collapsible="true" expanded="false"
                        style="-fx-background-color: #f8fafc; -fx-background-radius: 10;
                               -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10;">
                <VBox spacing="12" style="-fx-padding: 14;">
                    <HBox spacing="12">
                        <TextField fx:id="maxBidField"
                                   promptText="Giá tối đa (VNĐ)"
                                   prefWidth="220" prefHeight="40"/>
                        <TextField fx:id="incrementField"
                                   promptText="Bước giá"
                                   prefWidth="150" prefHeight="40"/>
                        <Button text="Bật Auto-Bid" onAction="#handleAutoBid"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                       -fx-padding: 9 22; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </TitledPane>
        </VBox>
    </bottom>
</BorderPane>