<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.AuctionDashboardController"
            prefHeight="700"
            prefWidth="1200"
            style="-fx-background-color: #f0f2f5;">

    <!-- TOP HEADER -->
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 14 22; -fx-background-color: white;
                     -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <Label text="🏷 Latest Auctions"
                   style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Button text="⟳ Làm mới" onAction="#handleRefresh"
                    style="-fx-background-color: #eff6ff; -fx-text-fill: #2563eb;
                           -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-border-color: #bfdbfe; -fx-border-width: 1;
                           -fx-border-radius: 8; -fx-cursor: hand;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <fx:include source="/com/auction/client/fxml/ProfileMenu.fxml"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="16" style="-fx-padding: 22;">
            <TextField fx:id="searchField" promptText="🔍  Tìm kiếm sản phẩm..."
                       prefHeight="42"
                       style="-fx-background-color: white; -fx-background-radius: 10;
                              -fx-border-radius: 10; -fx-border-color: #e5e7eb;
                              -fx-border-width: 1.5; -fx-font-size: 13.5px; -fx-padding: 8 14;"/>

            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <TilePane fx:id="auctionGrid"
                          hgap="20" vgap="20"
                          prefColumns="4"
                          tileAlignment="CENTER"
                          style="-fx-background-color: transparent; -fx-padding: 4;"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>