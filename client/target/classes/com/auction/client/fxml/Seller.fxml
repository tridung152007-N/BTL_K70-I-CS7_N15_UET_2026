<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.SellerController"
            style="-fx-background-color: #f0f2f5;">

    <!-- Top Bar -->
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 14 22; -fx-background-color: white;
                     -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <Label text="📦  Quản lý sản phẩm — Seller"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Button text="⟳ Làm mới" onAction="#handleRefresh"
                    style="-fx-background-color: #eff6ff; -fx-text-fill: #2563eb;
                           -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-border-color: #bfdbfe; -fx-border-width: 1;
                           -fx-border-radius: 8; -fx-cursor: hand;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <fx:include source="/com/auction/client/fxml/ProfileMenu.fxml"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.45" style="-fx-padding: 16; -fx-background-color: #f0f2f5;">

            <!-- LEFT: Item List -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
                <Label text="Danh sách sản phẩm"
                       style="-fx-font-weight: bold; -fx-font-size: 14.5px; -fx-text-fill: #1e293b;"/>
                <TableView fx:id="itemTable" prefHeight="600"
                           style="-fx-background-radius: 9; -fx-border-color: #e5e7eb;
                                  -fx-border-radius: 9;">
                    <columns>
                        <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="220"/>
                        <TableColumn fx:id="colCategory" text="Loại" prefWidth="130"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- RIGHT: Form -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12;
                                       -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">

                <Label text="Thông tin sản phẩm"
                       style="-fx-font-weight: bold; -fx-font-size: 14.5px; -fx-text-fill: #1e293b;"/>
                <TextField fx:id="nameField" promptText="Tên sản phẩm" prefHeight="40"/>
                <TextArea fx:id="descField" promptText="Mô tả" prefHeight="70"
                          style="-fx-background-radius: 8; -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db; -fx-border-width: 1.5;"/>
                <ComboBox fx:id="categoryBox" promptText="Chọn loại sản phẩm"
                          maxWidth="1.7976931348623157E308" prefHeight="40"/>

                <VBox fx:id="electronicsFields" spacing="8">
                    <TextField fx:id="brandField" promptText="Thương hiệu" prefHeight="40"/>
                    <TextField fx:id="warrantyField" promptText="Thời gian bảo hành (tháng)" prefHeight="40"/>
                </VBox>
                <VBox fx:id="artFields" spacing="8" visible="false" managed="false">
                    <TextField fx:id="artistField" promptText="Nghệ sĩ" prefHeight="40"/>
                    <TextField fx:id="artYearField" promptText="Năm sáng tác" prefHeight="40"/>
                </VBox>
                <VBox fx:id="vehicleFields" spacing="8" visible="false" managed="false">
                    <TextField fx:id="kmField" promptText="Số km đã chạy" prefHeight="40"/>
                    <TextField fx:id="mfYearField" promptText="Năm sản xuất" prefHeight="40"/>
                </VBox>

                <HBox spacing="8">
                    <Button text="Thêm mới" onAction="#handleAdd"
                            style="-fx-background-color: #16a34a; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"
                            styleClass="button-success"/>
                    <Button text="Sửa" onAction="#handleEdit"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button text="Xóa" onAction="#handleDelete"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button text="Làm sạch" onAction="#handleClear"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                                   -fx-background-radius: 8; -fx-border-color: #e2e8f0;
                                   -fx-border-width: 1; -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="📸  Chọn ảnh" onAction="#handleChooseImage"
                            style="-fx-background-color: #f8fafc; -fx-text-fill: #374151;
                                   -fx-background-radius: 8; -fx-border-color: #d1d5db;
                                   -fx-border-width: 1; -fx-border-radius: 8; -fx-cursor: hand;"/>
                    <Label fx:id="imagePathLabel" text="Chưa chọn ảnh"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 12.5px;"/>
                </HBox>

                <Separator style="-fx-padding: 4 0;"/>

                <Label text="Tạo phiên đấu giá"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #16a34a;"/>
                <TextField fx:id="startingPriceField" promptText="Giá khởi điểm (VNĐ)" prefHeight="40"/>
                <TextField fx:id="durationHoursField" promptText="Thời gian đấu giá (giờ)" prefHeight="40"/>

                <Button text="🚀  Tạo phiên đấu giá" onAction="#handleCreateAuction"
                        prefHeight="44" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white;
                               -fx-font-size: 14.5px; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-cursor: hand;"/>

                <Label fx:id="statusLabel"
                       style="-fx-font-size: 13px; -fx-wrap-text: true;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>