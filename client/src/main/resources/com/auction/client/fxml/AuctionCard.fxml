<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.components.AuctionCard"
      prefWidth="260"
      spacing="10"
      styleClass="auction-card"
      style="-fx-background-color: white;
             -fx-background-radius: 14;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.09), 14, 0, 0, 4);
             -fx-cursor: hand;
             -fx-padding: 18 18 16 18;">

    <!-- Top accent bar -->
    <Rectangle width="36" height="4" arcWidth="4" arcHeight="4"
               style="-fx-fill: #2563eb;"/>

    <Label fx:id="nameLabel"
           style="-fx-font-size: 14.5px; -fx-font-weight: bold;
                  -fx-text-fill: #1e293b; -fx-wrap-text: true;"
           maxWidth="224"/>

    <HBox alignment="CENTER_LEFT" spacing="6">
        <Label text="Giá hiện tại"
               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
    </HBox>

    <Label fx:id="priceLabel"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>

    <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 4 0 0 0;">
        <Label text="⏱"
               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
        <Label text="Nhấn để tham gia đấu giá"
               style="-fx-font-size: 11.5px; -fx-text-fill: #94a3b8;"/>
    </HBox>
</VBox>