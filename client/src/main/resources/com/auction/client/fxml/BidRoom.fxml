<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.BidRoomController"
            prefWidth="980"
            prefHeight="700"
            style="-fx-background-color: #f8f9fa;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT">

            <Button text="← Quay lại"
                    onAction="#goBack"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>

            <Label fx:id="itemNameLabel"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <Label text="Giá hiện tại:" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Label fx:id="currentPriceLabel"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>

            <Label fx:id="timerLabel"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </HBox>
    </top>

    <!-- CENTER: BIỂU ĐỒ LỊCH SỬ GIÁ -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="📈 Lịch sử đấu giá"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <StackPane fx:id="chartContainer"
                       prefHeight="420"
                       style="-fx-background-color: white;
                              -fx-border-color: #e0e0e0;
                              -fx-border-radius: 8;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);"/>
        </VBox>
    </center>

    <!-- BOTTOM: ĐẶT GIÁ -->
    <bottom>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">

            <!-- Đặt giá thủ công -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Đặt giá:" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                <TextField fx:id="bidAmountField"
                           promptText="Nhập số tiền (VNĐ)"
                           prefWidth="280"/>
                <Button text="💰 ĐẶT GIÁ NGAY"
                        onAction="#handleBid"
                        style="-fx-background-color: #27ae60;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-padding: 10 28;
                               -fx-font-size: 14px;"/>
            </HBox>

            <!-- Auto Bid -->
            <TitledPane text="🤖 Auto Bidding" collapsible="true" expanded="false">
                <VBox spacing="12" style="-fx-padding: 15;">
                    <HBox spacing="12">
                        <TextField fx:id="maxBidField"
                                   promptText="Giá tối đa (VNĐ)"
                                   prefWidth="220"/>
                        <TextField fx:id="incrementField"
                                   promptText="Bước giá"
                                   prefWidth="150"/>
                        <Button text="Bật Auto-Bid"
                                onAction="#handleAutoBid"
                                style="-fx-background-color: #3498db;
                                       -fx-text-fill: white;
                                       -fx-padding: 10 20;
                                       -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </TitledPane>
        </VBox>
    </bottom>
</BorderPane>