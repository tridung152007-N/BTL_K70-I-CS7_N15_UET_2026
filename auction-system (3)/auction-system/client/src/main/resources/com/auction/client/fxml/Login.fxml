<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.LoginController"
      spacing="16" alignment="CENTER" style="-fx-padding: 40;">
    <Label text="Đăng nhập" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <TextField fx:id="usernameField" promptText="Tên đăng nhập"/>
    <PasswordField fx:id="passwordField" promptText="Mật khẩu"/>
    <Button fx:id="loginBtn" text="Đăng nhập" onAction="#handleLogin"
            style="-fx-pref-width: 200;"/>
    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
</VBox>
